[Unit]
Description=RP2040 Robot Agent Bridge
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=/opt/picoclaw-rp2040/robot-agent
ExecStart=/opt/picoclaw-rp2040/.venv/bin/python /opt/picoclaw-rp2040/robot-agent/cli.py --config /opt/picoclaw-rp2040/robot-agent/config.yaml monitor
Restart=always
RestartSec=3
User=arif
Environment=PYTHONUNBUFFERED=1
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
